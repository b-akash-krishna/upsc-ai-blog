---
const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.entries(postFiles).map(([path, mod]) => ({
  url: path.replace('./', '/blog/').replace('.md', ''),
  frontmatter: (mod as any).frontmatter,
}));
posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<html>
<head><title>UPSC with AI — Blog</title></head>
<body>
<h1>UPSC with AI</h1>
<p>AI strategies for UPSC Mains answer writing</p>
{posts.map(post => (
  <div>
    <a href={post.url}>{post.frontmatter.title}</a>
    <p>{post.frontmatter.description}</p>
  </div>
))}
</body>
</html>
