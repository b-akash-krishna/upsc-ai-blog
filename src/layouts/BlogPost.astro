---
import '../styles/global.css';
export interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
  };
}
const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-IN', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={frontmatter.description} />
  <link rel="icon" href="/favicon.ico" />
  <title>{frontmatter.title} — UPSC with AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

  <nav class="navbar" id="navbar">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">UPSC<span class="accent"> with AI</span></a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Articles</a></li>
        <li><a href="https://upscwithai.gumroad.com/l/tltsuj" class="nav-cta" target="_blank" rel="noopener">Get 50 Prompts ₹199</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <div class="post-hero">
      <div class="container" style="max-width: 760px;">
        <a href="/blog" style="color: var(--muted); text-decoration: none; font-size: 0.85rem; display:inline-flex; align-items:center; gap:0.3rem; margin-bottom: 1.5rem;">
          ← Back to Articles
        </a>
        <span class="card-tag">UPSC AI</span>
        <h1>{frontmatter.title}</h1>
        <div class="post-meta">
          <span>📅 {formattedDate}</span>
          <span>📖 5 min read</span>
        </div>
      </div>
    </div>

    <div class="container">
      <article class="post-body">
        <slot />

        <div class="post-cta">
          <h3>Want 50 prompts like this?</h3>
          <p>Structured AI prompts for every GS paper — answer evaluation, dimension expansion, ethics frameworks.</p>
          <a href="https://upscwithai.gumroad.com/l/tltsuj" class="btn-gold" target="_blank" rel="noopener" style="display:inline-flex; align-items:center; gap:0.5rem;">
            Get All 50 Prompts — ₹199 →
          </a>
        </div>
      </article>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p class="footer-copy">© 2026 UPSC with AI</p>
      <div class="footer-links">
        <a href="/blog">Articles</a>
        <a href="https://upscwithai.gumroad.com/l/tltsuj" target="_blank" rel="noopener">Get Prompts</a>
      </div>
    </div>
  </footer>

</body>



<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 40);
  });
</script>
</html>
